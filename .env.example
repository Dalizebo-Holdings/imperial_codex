# Imperial Codex v16 — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ============================================================
# AI Provider Keys
# ============================================================

# OpenAI API key — used by the AI Chat Assistant (GPT-4o) and Background Agent
# Format: sk-... (starts with "sk-")
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API key — used by the Claude Strike Output Engine (claude-3-5-sonnet)
# Format: sk-ant-... (starts with "sk-ant-")
# Obtain from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ============================================================
# Supabase Database
# ============================================================

# Supabase project URL
# Format: https://<project-ref>.supabase.co
# Obtain from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=

# Supabase anonymous (public) API key — used for standard client operations
# Format: JWT string (eyJ...)
# Obtain from: Supabase Dashboard → Project Settings → API → anon public
SUPABASE_ANON_KEY=

# Supabase service role key — bypasses Row Level Security (used for vault and cron agent)
# Format: JWT string (eyJ...)
# Obtain from: Supabase Dashboard → Project Settings → API → service_role
# WARNING: Keep this secret — never expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Security
# ============================================================

# AES-256-GCM encryption key for the Vault (clearance codes)
# Format: 64-character hexadecimal string (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_ENCRYPTION_KEY=

# iron-session cookie encryption secret
# Format: Any string of 32+ characters (longer is better)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ============================================================
# Vercel Cron
# ============================================================

# Secret token for authenticating cron requests to /api/agent/cron
# Format: Any secure random string (32+ characters recommended)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used by both Vercel (Authorization: Bearer header) and Coolify cron runner
CRON_SECRET=

# ============================================================
# Webhooks (Optional)
# ============================================================

# Webhook URL for critical loop alerts from the Background Agent
# Format: HTTPS URL (e.g., Slack incoming webhook or custom endpoint)
# If not set, webhook alerts are silently skipped
# Example: https://hooks.slack.com/services/T.../B.../...
WEBHOOK_ALERT_URL=

# ============================================================
# MCP Integration (External Services)
# ============================================================

# Brave Search API key — enables web search in the AI chat assistant
# Format: BSA... (Brave Search API key)
# Obtain from: https://api.search.brave.com/app/keys
# If not set, web search tool is not exposed to the chat agent
BRAVE_API_KEY=

# Slack Bot Token — enables rich formatted alerts for critical loop triggers
# Format: xoxb-... (Slack Bot OAuth token)
# Obtain from: https://api.slack.com/apps → OAuth & Permissions
# If not set, falls back to raw webhook (WEBHOOK_ALERT_URL)
SLACK_BOT_TOKEN=

# Slack alert channel — where critical loop alerts are posted
# Format: #channel-name
# Default: #imperial-codex-alerts
SLACK_ALERT_CHANNEL=#imperial-codex-alerts

# GitHub Personal Access Token — enables repo file read/write in the chat agent
# Format: ghp_... or github_pat_...
# Obtain from: https://github.com/settings/tokens (needs repo scope)
# If not set, GitHub tools are not exposed to the chat agent
GITHUB_TOKEN=

# GitHub repository — the repo the GitHub tools operate on
# Format: owner/repo (e.g., dalizebo/imperial-codex)
GITHUB_REPO=

# MCP Server URL — the public URL of the deployed Imperial Codex MCP HTTP endpoint
# Format: https://your-deployment.vercel.app
# Used in mcp-config.json for remote HTTP transport configuration
MCP_SERVER_URL=

# ============================================================
# Amazon Q Configuration
# ============================================================

# AWS Profile for Amazon Q CLI
# Format: profile name from ~/.aws/config (e.g., amazon-q)
# Default: amazon-q or default
AWS_PROFILE=amazon-q

# AWS Region for Amazon Q services
# Format: AWS region code (e.g., us-east-1, eu-west-1)
# Default: us-east-1
AWS_REGION=us-east-1

# Amazon Q Development Mode
# Format: true or false
# When true, enables verbose logging and development features
AMAZON_Q_DEV_MODE=true

# Amazon Q Share Usage Data
# Format: true or false
# When true, anonymized usage data is collected to improve Amazon Q
AMAZON_Q_SHARE_USAGE_DATA=true
